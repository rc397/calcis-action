{
  "name": "calcis-action",
  "version": "1.1.0",
  "private": true,
  "description": "GitHub Action that estimates LLM API costs on PRs, shows cost deltas vs the base branch, and gates merges on .calcis.yml budget thresholds.",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@vercel/ncc": "^0.38.3",
    "typescript": "^5.3.3"
  }
}
